{
  "name": "frontend",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "generate-env": "tsx scripts/generate-env.ts",
    "start": "npm run generate-env && ng serve",
    "build:dev": "npm run generate-env && ng build --configuration development",
    "build:local": "npm run generate-env && ng build --configuration production --base-href /fake-news-combat-client/",
    "build:dom": "ng build --configuration production --base-href /",
    "deploy:local": "sh -c \"$DEPLOY_LOCAL\"",
    "deploy:domain": "sh -c \"$DEPLOY_DOMAIN\"",
    "watch": "ng build --watch --configuration development",
    "test": "ng test"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "packageManager": "npm@10.8.2",
  "dependencies": {
    "@angular/animations": "^21.1.0",
    "@angular/cdk": "21.1.6",
    "@angular/common": "^21.1.0",
    "@angular/compiler": "^21.1.0",
    "@angular/core": "^21.1.0",
    "@angular/forms": "^21.1.0",
    "@angular/platform-browser": "^21.1.0",
    "@angular/platform-browser-dynamic": "^21.1.0",
    "@angular/router": "^21.1.0",
    "@fortawesome/fontawesome-free": "^7.2.0",
    "primeicons": "^7.0.0",
    "primeng": "^21.1.1",
    "recaptcha-v3": "^1.11.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^21.1.3",
    "@angular/cli": "^21.1.3",
    "@angular/compiler-cli": "^21.1.0",
    "@angular/material": "21.1.6",
    "@types/node": "^25.3.5",
    "angular-cli-ghpages": "^3.0.2",
    "cpy-cli": "^7.0.0",
    "dotenv": "^17.3.1",
    "jsdom": "^27.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.8"
  }
}
